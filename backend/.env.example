# backend/.env.example
APP_NAME=PAT
DEBUG=false
SECRET_KEY=change-me-to-a-32-char-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

DATABASE_URL=postgresql+asyncpg://pat:pat@localhost:5432/pat
REDIS_URL=redis://localhost:6379/0
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

QDRANT_HOST=qdrant
QDRANT_PORT=6333

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://ollama:11434

TELEGRAM_BOT_TOKEN=
# Public URL of the frontend — used in Telegram notification links
FRONTEND_URL=http://localhost:3000

MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=/tmp/pat_uploads
EXPORT_DIR=/tmp/pat_exports

CORS_ORIGINS=["http://localhost:3000"]
